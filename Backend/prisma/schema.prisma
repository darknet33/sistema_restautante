generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  CAJERO
  MESERO
  COCINA
}

enum TableStatus {
  LIBRE
  OCUPADA
  RESERVADA
  LIMPIEZA
}

enum OrderStatus {
  PENDIENTE
  EN_COCINA
  LISTO
  SERVIDO
  PAGADO
  ENTREGADO
}

enum OrderType {
  PARA_AQUI
  PARA_LLEVAR
  DELIVERY
}

enum MovementType {
  ENTRADA
  MERMA
  AJUSTE
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  email     String?  @unique
  password  String
  name      String
  role      UserRole @default(MESERO)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders         Order[]
  supplies       CajaSession[]
  movements      InventoryMovement[]
  turnoClosures  TurnoClosure[]
  wastes         Waste[]
}

model Category {
  id        Int      @id @default(autoincrement())
  name      String
  type      String   // 'plato' | 'bebida' | 'insumo'
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  dishes   Dish[]
  supplies Supply[]
}

model Dish {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  price       Decimal  @db.Decimal(10, 2)
  cost        Decimal  @db.Decimal(10, 2)
  categoryId  Int
  imageUrl    String?
  isAvailable Boolean  @default(true)
  isMenu      Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  category   Category    @relation(fields: [categoryId], references: [id])
  orderItems OrderItem[]
}

model Supply {
  id                 Int      @id @default(autoincrement())
  name               String
  unit               String   // 'unidad' | 'ml' | 'g' | 'porcion'
  purchaseCost       Decimal  @db.Decimal(10, 2) @default(0)
  salePrice          Decimal  @db.Decimal(10, 2) @default(0)
  stockCurrent       Decimal  @db.Decimal(10, 2) @default(0)
  stockMin           Decimal  @db.Decimal(10, 2) @default(0)
  categoryId         Int
  isInventoryTracked Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  category   Category           @relation(fields: [categoryId], references: [id])
  orderItems OrderItem[]
  movements  InventoryMovement[]
  wastes     Waste[]
}

model Table {
  id        Int         @id @default(autoincrement())
  number    Int         @unique
  seats     Int         @default(4)
  status    TableStatus @default(LIBRE)
  posX      Float?
  posY      Float?
  shape     String?     @default("circle")
  width     Float?      @default(80)
  height    Float?      @default(80)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  orders Order[]
}

model Order {
  id              Int         @id @default(autoincrement())
  tableId         Int?
  userId          Int
  orderType       OrderType   @default(PARA_AQUI)
  status          OrderStatus @default(PENDIENTE)
  total           Decimal     @db.Decimal(10, 2) @default(0)
  notes           String?
  deliveryAddress String?
  deliveryPhone   String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  table Table?     @relation(fields: [tableId], references: [id])
  user  User       @relation(fields: [userId], references: [id])
  items OrderItem[]
}

model OrderItem {
  id        Int      @id @default(autoincrement())
  orderId   Int
  dishId    Int?
  supplyId  Int?
  type      String   // 'dish' | 'supply'
  quantity  Decimal  @db.Decimal(10, 2)
  unitPrice Decimal  @db.Decimal(10, 2)
  costPrice Decimal  @db.Decimal(10, 2) @default(0)
  notes     String?
  served    Boolean  @default(false)
  createdAt DateTime @default(now())

  order  Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  dish   Dish?   @relation(fields: [dishId], references: [id])
  supply Supply? @relation(fields: [supplyId], references: [id])
}

model InventoryMovement {
  id          Int           @id @default(autoincrement())
  supplyId    Int
  type        MovementType
  quantity    Decimal       @db.Decimal(10, 2)
  stockBefore Decimal       @db.Decimal(10, 2)
  stockAfter  Decimal       @db.Decimal(10, 2)
  userId      Int
  createdAt   DateTime      @default(now())

  supply Supply @relation(fields: [supplyId], references: [id])
  user   User   @relation(fields: [userId], references: [id])
}

model Waste {
  id         Int      @id @default(autoincrement())
  supplyId   Int
  quantity   Decimal  @db.Decimal(10, 2)
  reason     String
  userId     Int
  createdAt  DateTime @default(now())

  supply Supply @relation(fields: [supplyId], references: [id])
  user   User   @relation(fields: [userId], references: [id])
}

model CajaSession {
  id            Int      @id @default(autoincrement())
  userId        Int
  openingAmount Decimal  @db.Decimal(10, 2)
  closingAmount Decimal? @db.Decimal(10, 2)
  openedAt      DateTime @default(now())
  closedAt      DateTime?
  status        String   @default("ABIERTA")

  user User @relation(fields: [userId], references: [id])
}

model TurnoClosure {
  id          Int      @id @default(autoincrement())
  userId      Int
  openedAt    DateTime @default(now())
  closedAt    DateTime?
  totalSales  Decimal  @db.Decimal(10, 2) @default(0)
  totalOrders Int      @default(0)
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}
